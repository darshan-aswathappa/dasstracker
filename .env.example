# Gmail SMTP credentials for notifications.
# GMAIL_USER is your full Gmail address.
# GMAIL_APP_PASSWORD is a 16-char App Password (Google Account > Security >
# 2-Step Verification > App passwords). NOT your normal Google password.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where notification emails are sent. Defaults to GMAIL_USER if unset.
NOTIFY_TO=you@gmail.com

# WhatsApp notifications via the free CallMeBot relay (optional).
# Setup: add +34 644 51 95 23 to your phone contacts, send it the WhatsApp
# message "I allow callmebot to send me messages", and it replies with your
# API key. CALLMEBOT_PHONE is YOUR number in international format (leading +).
# Leave both blank to disable WhatsApp; digests still go to email.
CALLMEBOT_PHONE=+1234567890
CALLMEBOT_APIKEY=1234567

# HTTP port for the local web UI.
PORT=3000

# Path to the SQLite database file (optional; defaults to data/tracker.db).
# DB_PATH=data/tracker.db
