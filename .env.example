# Gmail SMTP credentials for notifications.
# GMAIL_USER is your full Gmail address.
# GMAIL_APP_PASSWORD is a 16-char App Password (Google Account > Security >
# 2-Step Verification > App passwords). NOT your normal Google password.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where notification emails are sent. Defaults to GMAIL_USER if unset.
NOTIFY_TO=you@gmail.com

# HTTP port for the local web UI.
PORT=3000

# Path to the SQLite database file (optional; defaults to data/tracker.db).
# DB_PATH=data/tracker.db
